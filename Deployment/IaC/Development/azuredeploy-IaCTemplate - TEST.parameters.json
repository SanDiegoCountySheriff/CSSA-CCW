{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "deploy_rg": {
            "value": true 
        },
        "storageAccount": {
            "value": {
                "name": "test",
                "blobServices": {
                    "changeFeed": true,
                    "container": {
                        "deleteRetentionPolicy": true,
                        "retentionDays": 7
                    },
                    "restorePolicy": true,
                    "deleteRetentionPolicy": true,
                    "retentionDays": 7,
                    "isVersioningEnabled": true
                },
                "containers": [
                    "test-1",
                    "test-2"
                ],
                "fileServices": {
                    "retention": false,
                    "retentionDays": 7
                }
            }
        }
    }
}