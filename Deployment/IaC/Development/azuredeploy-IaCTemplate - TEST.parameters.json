{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "deploy_rg": {
            "value": true 
        },
        "storageAccount_fileServices_retention": {
            "value": false
        },
        "storageAccount_fileServices_retentionDays": {
            "value": 1
        },
        "storageAccount": {
            "value": {
                "name": "admin",
                "blobServices": {
                    "changeFeed": false,
                    "container": {
                        "deleteRetentionPolicy": true,
                        "retentionDays": 7
                    },
                    "restorePolicy": false,
                    "deleteRetentionPolicy": true,
                    "retentionDays": 7,
                    "isVersioningEnabled": false
                },
                "containers": []
            }
        }
    }
}