{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "deploy_rg": {
            "value": true 
        },
        "storageAccount": {
            "value": {
                "name": "test",
                "blobServices": {
                    "value": {
                        "changeFeed": true,
                            "container": {
                                "value": {
                                "deleteRetentionPolicy": true,
                                "retentionDays": 7
                            }
                        },
                        "restorePolicy": false,
                        "deleteRetentionPolicy": true,
                        "retentionDays": 7,
                        "isVersioningEnabled": true
                    }
                },
                "containers": [],
                "fileServices": {
                    "value": {
                        "retention": false,
                        "retentionDays": 7
                    }
                }
            }
        }
    }
}