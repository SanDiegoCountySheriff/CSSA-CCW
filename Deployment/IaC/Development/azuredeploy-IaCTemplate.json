{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "agency": {
            "type": "string",
            "defaultValue": "sdsd",
            "metadata": {
                "description": "Agency identifier varies based on agency."
            }
        },
        "appConfig": {
            "type": "object"
        },
        "application": {
            "type": "string",
            "defaultValue": "ccw"
        },
        "appService": {
            "type": "object"
        },
        "appServicePlan": {
            "type": "object"
        },
        "authentication": {
            "type": "object"
        },
        "cosmosDB": {
            "type": "object"
        },
        "dept": {
            "type": "string",
            "defaultValue": "it"
        },
        "environment": {
            "type": "string",
            "defaultValue": "dev",
            "allowedValues": [ "dev" ]
        },
        "insights": {
            "type": "object"
        },
        "keyVault_tenantId": {
            "type": "string",
            "defaultValue": "[subscription().tenantId]",
            "metadata": {
                "description": "Specifies the Azure Active Directory tenant ID that should be used for authenticating requests to the key vault. Get it by using Get-AzSubscription cmdlet."
            }
        },
        "keyVault": {
            "type": "object"
        },
        "logAnalytics": {
            "type": "object"
        },
        "owner_name": {
            "type": "string",
            "defaultValue": "jkellash"
        },
        "region": {
            "type": "string",
            "defaultValue": "[resourceGroup().location]"
        },
        "resource_appConfig": {
            "type": "string",
            "defaultValue": "ac"
        }, 
        "resource_appServicePlan": {
            "type": "string",
            "defaultValue": "asp"
        },
        "resource_cosmosDB": {
            "type": "string",
            "defaultValue": "cdb"
        },
        "resource_function": {
            "type": "string",
            "defaultValue": "fa"
        },
        "resource_insights": {
            "type": "string",
            "defaultValue": "ai"
        }, 
        "resource_keyVault": {
            "type": "string",
            "defaultValue": "kv"
        },
        "resource_logAnalytics": {
            "type": "string",
            "defaultValue": "law"
        }, 
        "resource_storageAccount": {
            "type": "string",
            "defaultValue": "sa"
        },
        "resource_webApp": {
            "type": "string",
            "defaultValue": "wa"
        },
        "rg_name": {
            "type": "string",
            "defaultValue": "[resourceGroup().name]"
        },
        "storageAccount": {
            "type": "object"
        }
    },
    "variables": {
        "appConfig_name": "[concat(parameters('resource_appConfig'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'), '-', parameters('appConfig').number)]",
        "appServicePlan_name": "[concat(parameters('resource_appServicePlan'), '-', parameters('resource_webApp'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'), '-', parameters('appServicePlan').number)]",
        "constant_name": "[concat(parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'))]",
        "cosmosDB_name": "[concat(parameters('resource_cosmosDB'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'), '-', parameters('cosmosDB').number)]",
        "insights_name": "[concat(parameters('resource_insights'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'))]",
        "keyVault_name": "[concat(parameters('resource_keyVault'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'), '-', parameters('keyVault').number)]",
        "logAnalytics_name": "[concat(parameters('resource_logAnalytics'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'))]",
        "sitesLogs_name": "[concat(parameters('resource_logAnalytics'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'), '-', parameters('insights').resourceLogs.name, '-', parameters('insights').resourceLogs.number)]",
        "storageAccount_name": "[concat(parameters('resource_storageAccount'), parameters('agency'), parameters('dept'), parameters('application'), parameters('environment'), if(empty(parameters('storageAccount').name), 'empty', parameters('storageAccount').name), parameters('storageAccount').number)]",
        "copy": [
            {
                "name": "appService_name",
                "count": "[if(empty(parameters('appService').sites[0].name), 0, length(parameters('appService').sites))]",
                "input": {
                    "name": "[concat(if(equals(parameters('appService').sites[copyIndex('appService_name')].function, true()), parameters('resource_function'), parameters('resource_webApp')), '-', variables('constant_name'), '-', parameters('appService').sites[copyIndex('appService_name')].name, '-', parameters('appService').sites[copyIndex('appService_name')].number)]"
                }
            },
            {
                "name": "insights_comp_name",
                "count": "[if(empty(parameters('appService').sites[0].name), 0, length(parameters('appService').sites))]",
                "input": {
                    "name": "[concat(variables('insights_name'), '-', parameters('appService').sites[copyIndex('insights_comp_name')].name, '-', parameters('appService').sites[copyIndex('insights_comp_name')].number)]"
                }
            },
            {
                "name": "keyVault_secrets_name",
                "count": "[if(empty(parameters('keyVault').secrets[0].name), 0, length(parameters('keyVault').secrets))]",
                "input": {
                    "name": "[concat(variables('keyVault_name'), '/', parameters('keyVault').secrets[copyIndex('keyVault_secrets_name')].name)]"
                }
            },
            {
                "name": "logAnalytics_workspaces_name",
                "count": "[if(empty(parameters('logAnalytics').workspaces[0].name), 0, length(parameters('logAnalytics').workspaces))]",
                "input": {
                    "name": "[concat(variables('logAnalytics_name'), '-', if(empty(parameters('logAnalytics').workspaces[copyIndex('logAnalytics_workspaces_name')].name), 'empty', parameters('logAnalytics').workspaces[copyIndex('logAnalytics_workspaces_name')].name), '-', parameters('logAnalytics').workspaces[copyIndex('logAnalytics_workspaces_name')].number)]"
                }
            },
            {
                "name": "roleAssignment_name",
                "count": "[if(empty(parameters('authentication').permissions[0].principalId), 0, length(parameters('authentication').permissions))]",
                "input": {
                    "name": "[guid(parameters('authentication').permissions[copyIndex('roleAssignment_name')].principalId, parameters('authentication').permissions[copyIndex('roleAssignment_name')].roleDefinition, resourceGroup().id)]"
                }
            },
            {
                "name": "storageAccount_container_name",
                "count": "[length(parameters('storageAccount').containers)]",
                "input": {
                    "name": "[concat(variables('storageAccount_name'), '/default/', parameters('storageAccount').containers[copyIndex('storageAccount_container_name')])]"
                }
            }
        ]
    },
    "resources": [
        {
            "condition": "[parameters('cosmosDB').deploy]",
            "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
            "apiVersion": "2022-08-15",
            "name": "[concat(variables('cosmosDB_name'), '/', if(empty(parameters('cosmosDB').sqlDatabases.id), 'empty', parameters('cosmosDB').sqlDatabases.id), '/', if(empty(parameters('cosmosDB').sqlDatabases.containers), 'empty', parameters('cosmosDB').sqlDatabases.containers[copyIndex('sqlDatabases_containers')]))]",
            "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', variables('cosmosDB_name'), if(empty(parameters('cosmosDB').sqlDatabases.id), 'empty', parameters('cosmosDB').sqlDatabases.id))]",
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosDB_name'))]"
            ],
            "properties": {
                "resource": {
                    "id": "[parameters('cosmosDB').sqlDatabases.containers[copyIndex('sqlDatabases_containers')]]",
                    "indexingPolicy": {
                        "indexingMode": "consistent",
                        "automatic": true,
                        "includedPaths": [
                            {
                                "path": "/*"
                            }
                        ],
                        "excludedPaths": [
                            {
                                "path": "/\"_etag\"/?"
                            }
                        ]
                    },
                    "partitionKey": {
                        "paths": [
                            "/id"
                        ],
                        "kind": "Hash"
                    },
                    "uniqueKeyPolicy": {
                        "uniqueKeys": []
                    },
                    "conflictResolutionPolicy": {
                        "mode": "LastWriterWins",
                        "conflictResolutionPath": "/_ts"
                    }
                }
            },
            "copy": {
                "name": "sqlDatabases_containers",
                "count": "[length(parameters('cosmosDB').sqlDatabases.containers)]"
            }
        },
        {
            "condition": "[and(parameters('cosmosDB').deploy, not(empty(parameters('cosmosDB').sqlDatabases.id)))]",
            "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
            "apiVersion": "2022-08-15",
            "name": "[concat(variables('cosmosDB_name'), '/', if(empty(parameters('cosmosDB').sqlDatabases.id), 'null', parameters('cosmosDB').sqlDatabases.id))]",
            "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosDB_name'))]"
            ],
            "properties": {
                "resource": {
                    "id": "[parameters('cosmosDB').sqlDatabases.id]"
                }
            }
        },
        {
            "condition": "[parameters('storageAccount').deploy]",
            "type": "Microsoft.Storage/storageAccounts/blobServices",
            "apiVersion": "2022-05-01",
            "name": "[concat(variables('storageAccount_name'), '/default')]",
            "location": "[parameters('region')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "properties": {
                "changeFeed": {
                    "enabled": "[parameters('storageAccount').blobServices.changeFeed]"
                },
                "restorePolicy": {
                    "enabled": "[parameters('storageAccount').blobServices.restorePolicy]"
                },
                "containerDeleteRetentionPolicy": {
                    "enabled": "[parameters('storageAccount').blobServices.container.deleteRetentionPolicy]",
                    "days": "[parameters('storageAccount').blobServices.container.retentionDays]"
                },
                "cors": {
                    "corsRules": []
                },
                "deleteRetentionPolicy": {
                    "allowPermanentDelete": false,
                    "enabled": "[parameters('storageAccount').blobServices.deleteRetentionPolicy]",
                    "days": "[parameters('storageAccount').blobServices.retentionDays]"
                },
                "isVersioningEnabled": "[parameters('storageAccount').blobServices.isVersioningEnabled]"
            }
        },
        {
            "condition": "[parameters('appService').deploy]",
            "type": "Microsoft.Web/sites",
            "apiVersion": "2022-03-01",
            "name": "[if(empty(parameters('appService').sites[0].name), variables('constant_name'), variables('appService_name')[copyIndex('sites')].name)]",
            "location": "[parameters('region')]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlan_name'))]"
            ],
            "tags": {
                "agency_name": "[parameters('agency')]",
                "agency_ori": "ca0370000",
                "application_name": "[parameters('application')]",
                "business_unit": "[parameters('dept')]",
                "criticality": "low",
                "data_classification": "general",
                "environment": "[parameters('environment')]",
                "owner_name": "[concat(parameters('owner_name'), '@californiasheriffs.onmicrosoft.com')]",
                "start_date": "09/29/2022"
            },
            "kind": "[if(equals(parameters('appService').sites[copyIndex('sites')].function, true()), concat('functionapp,linux'), concat('app,linux'))]", // "app,linux",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "enabled": true,
                "hostNameSslStates": [
                    {
                        "name": "[concat(variables('appService_name')[copyIndex('sites')].name, '.azurewebsites.us')]",
                        "sslState": "Disabled",
                        "hostType": "Standard"
                    },
                    {
                        "name": "[concat(variables('appService_name')[copyIndex('sites')].name, '.scm.azurewebsites.us')]",
                        "sslState": "Disabled",
                        "hostType": "Repository"
                    }
                ],
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlan_name'))]",
                "reserved": true,
                "isXenon": false,
                "hyperV": false,
                "vnetRouteAllEnabled": false,
                "vnetImagePullEnabled": false,
                "vnetContentShareEnabled": false,
                "siteConfig": {
                    "functionAppScaleLimit": "[if(equals(parameters('appService').sites[copyIndex('sites')].function, true()), 200, 0)]"
                },
                "scmSiteAlsoStopped": false,
                "clientAffinityEnabled": false,
                "clientCertEnabled": false,
                "clientCertMode": "Required",
                "hostNamesDisabled": false,
                "customDomainVerificationId": "9FE01B0A8428EC8A4CD7CDDBE9F3E3D2A089A715319DF71C18A08E8B1F0FE4EE",
                "containerSize": "[if(equals(parameters('appService').sites[copyIndex('sites')].function, true()), 1536, 0)]",
                "dailyMemoryTimeQuota": 0,
                "httpsOnly": true,
                "redundancyMode": "None",
                "storageAccountRequired": false,
                "keyVaultReferenceIdentity": "SystemAssigned"
            },
            "resources": [
                {
                    "type": "Microsoft.Web/sites/hostNameBindings",
                    "apiVersion": "2022-03-01",
                    "name": "[if(empty(variables('appService_name')), concat(variables('constant_name'), '/', variables('constant_name'), '.azurewebsites.us'), concat(variables('appService_name')[copyIndex('sites')].name, '/', variables('appService_name')[copyIndex('sites')].name, '.azurewebsites.us'))]",
                    "location": "[parameters('region')]",
                    "dependsOn": [
                        "[resourceId('Microsoft.Web/sites', if(empty(variables('appService_name')), variables('constant_name'), variables('appService_name')[copyIndex('sites')].name))]"
                    ],
                    "properties": {
                        "siteName": "[if(empty(parameters('appService').sites[0].name), variables('constant_name'), variables('appService_name')[copyIndex('sites')].name)]",
                        "hostNameType": "Verified"
                    }
                },
                {
                    "type": "Microsoft.Web/sites/config",
                    "apiVersion": "2022-03-01",
                    "name": "[if(empty(variables('appService_name')), concat(variables('constant_name'), '/web'), concat(variables('appService_name')[copyIndex('sites')].name, '/web'))]",
                    "location": "[parameters('region')]",
                    "dependsOn": [
                        "[resourceId('Microsoft.Web/sites', if(empty(variables('appService_name')), variables('constant_name'), variables('appService_name')[copyIndex('sites')].name))]"
                    ],
                    "tags": {
                        "agency_name": "[parameters('agency')]",
                        "agency_ori": "ca0370000",
                        "application_name": "[parameters('application')]",
                        "business_unit": "[parameters('dept')]",
                        "criticality": "low",
                        "data_classification": "general",
                        "environment": "[parameters('environment')]",
                        "owner_name": "[concat(parameters('owner_name'), '@californiasheriffs.onmicrosoft.com')]",
                        "start_date": "09/29/2022"
                    },
                    "properties": {
                        "numberOfWorkers": 1,
                        "defaultDocuments": [
                            "Default.htm",
                            "Default.html",
                            "Default.asp",
                            "index.htm",
                            "index.html",
                            "iisstart.htm",
                            "default.aspx",
                            "index.php",
                            "hostingstart.html"
                        ],
                        "netFrameworkVersion": "v4.0",
                        "linuxFxVersion": "DOTNETCORE|6.0",
                        "requestTracingEnabled": false,
                        "remoteDebuggingEnabled": false,
                        "remoteDebuggingVersion": "VS2019",
                        "httpLoggingEnabled": false,
                        "acrUseManagedIdentityCreds": false,
                        "logsDirectorySizeLimit": 35,
                        "detailedErrorLoggingEnabled": false,
                        "publishingUsername": "[concat('$', variables('appService_name')[copyIndex('sites')].name)]",
                        "scmType": "None",
                        "use32BitWorkerProcess": true,
                        "webSocketsEnabled": false,
                        "alwaysOn": "[parameters('appService').sites[copyIndex('sites')].function]",
                        "managedPipelineMode": "Integrated",
                        "virtualApplications": [
                            {
                                "virtualPath": "/",
                                "physicalPath": "site\\wwwroot",
                                "preloadEnabled": true
                            }
                        ],
                        "loadBalancing": "LeastRequests",
                        "experiments": {
                            "rampUpRules": []
                        },
                        "autoHealEnabled": false,
                        "vnetRouteAllEnabled": false,
                        "vnetPrivatePortsCount": 0,
                        "localMySqlEnabled": false,
                        "managedServiceIdentityId": 2957,
                        "ipSecurityRestrictions": [
                            {
                                "ipAddress": "Any",
                                "action": "Allow",
                                "priority": 2147483647,
                                "name": "Allow all",
                                "description": "Allow all access"
                            }
                        ],
                        "scmIpSecurityRestrictions": [
                            {
                                "ipAddress": "Any",
                                "action": "Allow",
                                "priority": 2147483647,
                                "name": "Allow all",
                                "description": "Allow all access"
                            }
                        ],
                        "scmIpSecurityRestrictionsUseMain": true,
                        "http20Enabled": false,
                        "minTlsVersion": "1.2",
                        "scmMinTlsVersion": "1.2",
                        "ftpsState": "Disabled",
                        "preWarmedInstanceCount": 0,
                        "healthCheckPath": "/api/health",
                        "functionsRuntimeScaleMonitoringEnabled": false,
                        "minimumElasticInstanceCount": 0,
                        "azureStorageAccounts": {}
                    }
                }
            ],
            "copy": {
                "name": "sites",
                "count": "[length(variables('appService_name'))]"
            }
        },
        {
            "condition": "[or(parameters('appService').deploy, parameters('insights').deploy)]",
            "type": "microsoft.insights/components",
            "apiVersion": "2020-02-02",
            "name": "[if(empty(parameters('appService').sites[0].name), variables('constant_name'), variables('insights_comp_name')[copyIndex('insights')].name)]",
            "location": "[parameters('region')]",
            "dependsOn": [
                "[resourceid('Microsoft.Operationalinsights/workspaces', variables('sitesLogs_name'))]"//,
                //"sites"
            ],
            "tags": {
                "agency_name": "[parameters('agency')]",
                "agency_ori": "ca0370000",
                "application_name": "[parameters('application')]",
                "business_unit": "[parameters('dept')]",
                "criticality": "low",
                "data_classification": "general",
                "environment": "[parameters('environment')]",
                "owner_name": "[concat(parameters('owner_name'), '@californiasheriffs.onmicrosoft.com')]",
                "start_date": "09/29/2022"
            },
            "kind": "web",
            "properties": {
                "Application_Type": "web",
                "Flow_Type": "Bluefield",
                "Request_Source": "Rest",
                "RetentionInDays": 90,
                "WorkspaceResourceId": "[resourceid('Microsoft.Operationalinsights/workspaces', variables('sitesLogs_name'))]",
                "IngestionMode": "LogAnalytics",
                "publicNetworkAccessForIngestion": "Enabled",
                "publicNetworkAccessForQuery": "Enabled"
            },
            "copy": {
                "name": "insights",
                "count": "[length(variables('insights_comp_name'))]"
            }
        },
        {
            "condition": "[parameters('authentication').deploy]",
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[if(empty(parameters('authentication').permissions[0].principalId), variables('constant_name'), variables('roleAssignment_name')[copyIndex('roleAssignments')].name)]",
            "properties": {
                "roleDefinitionId": "[resourceId('Microsoft.Authorization/roleDefinitions', parameters('authentication').permissions[copyIndex('roleAssignments')].roleDefinition)]",
                "principalId": "[parameters('authentication').permissions[copyIndex('roleAssignments')].principalId]"
            },
            "copy": {
                "name": "roleAssignments",
                "count": "[length(variables('roleAssignment_name'))]"
            }
        },
        {
            "condition": "[parameters('keyVault').deploy]",
            "type": "Microsoft.KeyVault/vaults/secrets",
            "apiVersion": "2022-07-01",
            "name": "[if(empty(parameters('keyVault').secrets[copyIndex('secrets')].name), concat(variables('keyVault_name'), '/empty'), variables('keyVault_secrets_name')[copyIndex('secrets')].name)]",
            "location": "[parameters('region')]",
            "dependsOn": [
                "[resourceId('Microsoft.KeyVault/vaults', variables('keyVault_name'))]"
            ],
            "properties": {
                "attributes": {
                    "enabled": true
                },
                "contentType": "string",
                "value": "[parameters('keyVault').secrets[copyIndex('secrets')].value]"
            },
            "copy": {
                "name": "secrets",
                "count": "[length(variables('keyVault_secrets_name'))]"
            }
        },
        {
            "condition": "[parameters('storageAccount').deploy]",
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2022-05-01",
            "name": "[if(empty(parameters('storageAccount').containers), concat(variables('storageAccount_name'), '/default/empty'), variables('storageAccount_container_name')[copyIndex('blobServices_containers')].name)]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccount_name'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "properties": {
                "immutableStorageWithVersioning": {
                    "enabled": false
                },
                "defaultEncryptionScope": "$account-encryption-key",
                "denyEncryptionScopeOverride": false,
                "publicAccess": "None"
            },
            "copy": {
                "name": "blobServices_containers",
                "count": "[length(variables('storageAccount_container_name'))]"
            }
        },
        {
            "condition": "[parameters('logAnalytics').deploy]",
            "type": "Microsoft.Operationalinsights/workspaces",
            "apiVersion": "2021-12-01-preview",
            "name": "[if(empty(variables('logAnalytics_workspaces_name')), variables('constant_name'), variables('logAnalytics_workspaces_name')[copyIndex('workspaces')].name)]",
            "location": "[parameters('region')]",
            "properties": {
                "sku": {
                    "name": "pergb2018"
                },
                "retentionInDays": 30,
                "features": {
                    "enableLogAccessUsingOnlyResourcePermissions": true
                },
                "workspaceCapping": {
                    "dailyQuotaGb": -1
                },
                "publicNetworkAccessForIngestion": "Disabled",
                "publicNetworkAccessForQuery": "Disabled"
            },
            "copy": {
                "name": "workspaces",
                "count": "[length(variables('logAnalytics_workspaces_name'))]"
            }
        },
        {
            "condition": "[parameters('appConfig').deploy]",
            "type": "Microsoft.AppConfiguration/configurationStores",
            "apiVersion": "2022-05-01",
            "name": "[variables('appConfig_name')]",
            "location": "[parameters('region')]",
            "tags": {
                "agency_name": "[parameters('agency')]",
                "agency_ori": "ca0370000",
                "application_name": "[parameters('application')]",
                "business_unit": "[parameters('dept')]",
                "criticality": "low",
                "data_classification": "general",
                "environment": "[parameters('environment')]",
                "owner_name": "[concat(parameters('owner_name'), '@californiasheriffs.onmicrosoft.com')]",
                "start_date": "09/29/2022"
            },
            "sku": {
                "name": "standard"
            },
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "encryption": {},
                "publicNetworkAccess": "Disabled",
                "disableLocalAuth": false,
                "softDeleteRetentionInDays": 1,
                "enablePurgeProtection": false
            }
        },
        {
            "condition": "[parameters('appServicePlan').deploy]",
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2022-03-01",
            "name": "[variables('appServicePlan_name')]",
            "location": "[parameters('region')]",
            "tags": {
                "agency_name": "[parameters('agency')]",
                "agency_ori": "ca0370000",
                "application_name": "[parameters('application')]",
                "business_unit": "[parameters('dept')]",
                "criticality": "low",
                "data_classification": "general",
                "environment": "[parameters('environment')]",
                "owner_name": "[concat(parameters('owner_name'), '@californiasheriffs.onmicrosoft.com')]",
                "start_date": "09/29/2022"
            },
            "sku": {
                "name": "B1",
                "tier": "Basic",
                "size": "B1",
                "family": "B",
                "capacity": 1
            },
            "kind": "linux",
            "properties": {
                "perSiteScaling": false,
                "elasticScaleEnabled": false,
                "maximumElasticWorkerCount": 1,
                "isSpot": false,
                "reserved": true,
                "isXenon": false,
                "hyperV": false,
                "targetWorkerCount": 0,
                "targetWorkerSizeId": 0,
                "zoneRedundant": false
            }
        },
        {
            "condition": "[parameters('cosmosDB').deploy]",
            "type": "Microsoft.DocumentDB/databaseAccounts",
            "apiVersion": "2022-08-15",
            "name": "[variables('cosmosDB_name')]",
            "location": "[parameters('region')]",
            "tags": {
                "defaultExperience": "Core (SQL)",
                "hidden-cosmos-mmspecial": "",
                "agency_name": "[parameters('agency')]",
                "agency_ori": "ca0370000",
                "application_name": "[parameters('application')]",
                "business_unit": "[parameters('dept')]",
                "criticality": "low",
                "data_classification": "general",
