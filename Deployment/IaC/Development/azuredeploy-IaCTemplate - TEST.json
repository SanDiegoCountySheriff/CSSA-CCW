        {
            "condition": "[parameters('deploy_rg')]",
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2022-05-01",
            "name": "[variables('storageAccount_name')]",
            "location": "[parameters('region')]",
            "tags": {
                "agency_name": "[parameters('agency')]",
                "agency_ori": "ca0370000",
                "application_name": "[parameters('application')]",
                "business_unit": "it",
                "criticality": "low",
                "data_classification": "general",
                "environment": "[parameters('environment')]",
                "owner_name": "jkellash@californiasheriffs.onmicrosoft.com",
                "start_date": "09/29/2022"
            },
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "kind": "StorageV2",
            "properties": {
                "publicNetworkAccess": "Enabled",
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": true,
                "allowSharedKeyAccess": true,
                "networkAcls": {
                    "resourceAccessRules": [],
                    "bypass": "AzureServices",
                    "virtualNetworkRules": [
                        // {
                        //     "condition": "[equals(parameters('DeployNetworkResources'),'true')]",
                        //     "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworks_name'))]",
                        //     "action": "Allow",
                        //     "state": "Succeeded"
                        // }
                    ],
                    // "copy": [
                    //     {
                    //         "name": "virtualNetworkRules",
                    //         "count": "[if(equals(parameters('DeployNetworkResources'),'false'), 0, 1)]",
                    //         "input": {
                    //             "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworks_name'))]", //"[concat(parameters('virtualNetwork_externalid'), '/subnets/snet-sdsd-it-ccw-dev-fl-001')]",
                    //             "action": "Allow",
                    //             "state": "Succeeded"
                    //         }
                    //     }
                    // ],
                    "ipRules": [],
                    "defaultAction": "Allow"
                },
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                    "requireInfrastructureEncryption": false,
                    "services": {
                        "file": {
                            "keyType": "Account",
                            "enabled": true
                        },
                        "blob": {
                            "keyType": "Account",
                            "enabled": true
                        }
                    },
                    "keySource": "Microsoft.Storage"
                },
                "accessTier": "Hot",
                "resources": [
                    {
                        //"condition": "[parameters('deploy_rg')]",
                        "type": "blobServices",
                        "apiVersion": "2022-05-01",
                        "name": "/default",
                        "location": "[parameters('region')]",
                        "dependsOn": [
                            "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
                        ],
                        "sku": {
                            "name": "Standard_LRS",
                            "tier": "Standard"
                        },
                        "properties": {
                            "copy": [
                                {
                                    "name": "changeFeed",
                                    "count": "[if(equals(parameters('blobServices_changeFeed'),'off'), 0, 1)]",
                                    "input": {
                                        "enabled": "[if(equals(parameters('blobServices_changeFeed'),'true'), 'true', 'false')]"
                                    }
                                },
                                {
                                    "name": "restorePolicy",
                                    "count": "[if(equals(parameters('blobServices_restorepolicy'),'off'), 0, 1)]",
                                    "input": {
                                        "enabled": "[if(equals(parameters('blobServices_restorePolicy'),'true'), 'true', 'false')]"
                                    }
                                },
                                {
                                    "name": "containerDeleteRetentionPolicy",
                                    "count": "[if(equals(parameters('blobServices_containerDeleteRetentionPolicy'),'off'), 0, 1)]",
                                    "input": {
                                        "enabled": "[if(equals(parameters('blobServices_containerDeleteRetentionPolicy'),'true'), 'true', 'false')]",
                                        "days": "[parameters('blobServices_containerRetention_days')]"
                                    }
                                },
                                {
                                    "name": "isVersioningEnabled",
                                    "count": "[if(equals(parameters('blobServices_isVersioningEnabled'),'off'), 0, 1)]",
                                    "input": {
                                        "enabled": "[if(equals(parameters('blobServices_isVersioningEnabled'),'true'), 'true', 'false')]"
                                    }
                                }
                            ],
                            "cors": {
                                "corsRules": []
                            },
                            "deleteRetentionPolicy": {
                                "allowPermanentDelete": false,
                                "enabled": "[if(equals(parameters('blobServices_deleteRetentionPolicy'), 'true'), 'true', 'false')]",
                                "days": "[parameters('blobServices_retention_days')]"
                            }
                        },
                        "resources": [
                            {
                                //"condition": "[parameters('deploy_rg')]",
                                "type": "containers",
                                "apiVersion": "2022-05-01",
                                "name": "[variables('storageAccount_container_name')]",
                                "dependsOn": [
                                    "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccount_name'), 'default')]",
                                    "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
                                ],
                                "properties": {
                                    "immutableStorageWithVersioning": {
                                        "enabled": false
                                    },
                                    "defaultEncryptionScope": "$account-encryption-key",
                                    "denyEncryptionScopeOverride": false,
                                    "publicAccess": "None"
                                }
                            }
                        ]
                    },
                    {
                        //"condition": "[parameters('deploy_rg')]",
                        "type": "fileServices",
                        "apiVersion": "2022-05-01",
                        "name": "/default",
                        "location": "[parameters('region')]",
                        "dependsOn": [
                            "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
                        ],
                        "sku": {
                            "name": "Standard_LRS",
                            "tier": "Standard"
                        },
                        "properties": {
                            "protocolSettings": {
                                "smb": {}
                            },
                            "cors": {
                                "corsRules": []
                            },
                            "shareDeleteRetentionPolicy": {
                                "enabled": "[if(equals(parameters('fileServices_retention'),'true'), 'true', 'false')]",
                                "days": "[parameters('fileServices_retentionDays')]"
                            }
                        }
                    },
                    {
                        "type": "queueServices",
                        "apiVersion": "2022-05-01",
                        "name": "/default",
                        "dependsOn": [
                            "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
                        ],
                        "properties": {
                            "cors": {
                                "corsRules": []
                            }
                        }
                    },
                    {
                        "type": "tableServices",
                        "apiVersion": "2022-05-01",
                        "name": "/default",
                        "dependsOn": [
                            "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
                        ],
                        "properties": {
                            "cors": {
                                "corsRules": []
                            }
                        }
                    }
                ]
            }
        }
    ],
    "outputs": {
        "resourcegroup_name": {
            "condition": "[parameters('deploy_rg')]",
            "type": "string",
            "value": "[parameters('rg_name')]"
        }
    }
}