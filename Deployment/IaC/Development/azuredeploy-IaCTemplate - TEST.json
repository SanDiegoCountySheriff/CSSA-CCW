        "fileServices_retentionDays": {
            "type": "int"
        },
        "region": {
            "defaultValue": "[resourceGroup().location]",
            "type": "string"
        },
        "rg_name": {
            "defaultValue": "[resourceGroup().name]",
            "type": "string"
        },
        "storageAccount": {
            "type": "String"
        }
