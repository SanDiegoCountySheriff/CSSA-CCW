{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "agency": {
            "defaultValue": "sdsd",
            "type": "string",
            "metadata": {
                "description": "Agency identifier varies based on agency."
            }
        },
        "application": {
            "defaultValue": "ccw",
            "type": "string"
        },
        "deploy_rg": {
            "type": "bool"
        },
        // "DeployNetworkResources": {
        //     "type": "Bool"
        // },
        "environment": {
            "defaultValue": "dev",
            "type": "string",
            "allowedValues": [ "dev" ]
        },
        "region": {
            "defaultValue": "[resourceGroup().location]",
            "type": "string"
        },
        "rg_name": {
            "defaultValue": "[resourceGroup().name]",
            "type": "string"
        },
        "logAnalytics": {
            "type": "object"
            //"type": "string"
        },
        "storageAccount": {
            "type": "object"
        }, 
        "keyVault": {
            "type": "object"
        },
        "cosmosDB": {
            "type": "object"
        }
        // "virtualNetwork_externalid": {
        //     "defaultValue": "/subscriptions/c74e04b6-0cd7-4778-863e-34654eb49270/resourceGroups/rg-sdsd-it-ccw-dev-001/providers/Microsoft.Network/virtualNetworks/vnet-sdsd-it-ccw-dev-001",
        //     "type": "string"
        // }
        // "virtualNetworks_vnet": {
        //     "defaultValue": "test",
        //     "type": "string"
        // }
    },
    "variables": {
        "copy": [
            {
                "name": "storageAccount_container_name",
                "count": "[if(empty(parameters('storageAccount').containers), 0, length(parameters('storageAccount').containers))]",
                "input": {
                    "name": "[concat(variables('storageAccount_name'), '/default/', parameters('storageAccount').containers[copyIndex('storageAccount_container_name')])]"
                }
            },
            {
                "name": "keyVault_secrets_name",
                "count": "[if(empty(parameters('keyVault').secrets), 0, length(parameters('keyVault').secrets))]",
                "input": {
                    "name": "[concat(variables('keyVault_name'), '/', parameters('keyVault').secrets[copyIndex('keyVault_secrets_name')])]"
                }
            }
        ],
        "storageAccount_name": "[concat(parameters('agency'), parameters('application'), parameters('environment'), if(empty(parameters('storageAccount').name), 'null', parameters('storageAccount').name), 'sa')]",
        "logAnalytics_name": "[concat(parameters('agency'), '-', parameters('application'), '-', parameters('environment'), '-', if(empty(parameters('logAnalytics').name), 'null', parameters('logAnalytics').name), '-law')]",
        "keyVault_name": "[concat(parameters('agency'), '-', parameters('application'), '-', parameters('environment'), '-kv')]",
        "cosmosDB_name": "[concat(parameters('agency'), '-', parameters('application'), '-', parameters('environment'), '-', if(empty(parameters('cosmosDB').name), 'null', parameters('cosmosDB').name), '-db')]"
        //"virtualNetworks_name": "[concat(parameters('agency'),'-', parameters('application'), '-',parameters('environment'),'-', parameters('virtualNetworks_vnet'), '-vnet')]"
    },
    "resources": [
        {
            "condition": "[parameters('storageAccount').deploy]",
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2022-05-01",
            "name": "[if(empty(parameters('storageAccount').containers), concat(variables('storageAccount_name'), '/default/empty'), variables('storageAccount_container_name')[copyIndex('blobServices_containers')].name)]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccount_name'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "properties": {
                "immutableStorageWithVersioning": {
                    "enabled": false
                },
                "defaultEncryptionScope": "$account-encryption-key",
                "denyEncryptionScopeOverride": false,
                "publicAccess": "None"
            },
            "copy": {
                "name": "blobServices_containers",
                "count": "[if(empty(parameters('storageAccount').containers), 0, length(variables('storageAccount_container_name')))]"
            }
        },
        {
            "condition": "[parameters('storageAccount').deploy]",
            "type": "Microsoft.Storage/storageAccounts/blobServices",
            "apiVersion": "2022-05-01",
            "name": "[concat(variables('storageAccount_name'), '/default')]",
            "location": "[parameters('region')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "properties": {
                "changeFeed": {
                    "enabled": "[parameters('storageAccount').blobServices.changeFeed]"
                },
                "restorePolicy": {
                    "enabled": "[parameters('storageAccount').blobServices.restorePolicy]"
                },
                "containerDeleteRetentionPolicy": {
                    "enabled": "[parameters('storageAccount').blobServices.container.deleteRetentionPolicy]",
                    "days": "[parameters('storageAccount').blobServices.container.retentionDays]"
                },
                "cors": {
                    "corsRules": []
                },
                "deleteRetentionPolicy": {
                    "allowPermanentDelete": false,
                    "enabled": "[parameters('storageAccount').blobServices.deleteRetentionPolicy]",
                    "days": "[parameters('storageAccount').blobServices.retentionDays]"
                },
                "isVersioningEnabled": "[parameters('storageAccount').blobServices.isVersioningEnabled]"
            }
        },
        {
            // "condition": "[and(parameters('deploy_rg'), not(equals(parameters('storageAccount').name, 'null')))]",
            "condition": "[parameters('storageAccount').deploy]",
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2022-05-01",
            "name": "[variables('storageAccount_name')]",
            "location": "[parameters('region')]",
            "tags": {
                "agency_name": "[parameters('agency')]",
                "agency_ori": "ca0370000",
                "application_name": "[parameters('application')]",
                "business_unit": "it",
                "criticality": "low",
                "data_classification": "general",
                "environment": "[parameters('environment')]",
                "owner_name": "jkellash@californiasheriffs.onmicrosoft.com",
                "start_date": "09/29/2022"
            },
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "kind": "StorageV2",
            "properties": {
                "publicNetworkAccess": "Enabled",
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": true,
                "allowSharedKeyAccess": true,
                "networkAcls": {
                    "resourceAccessRules": [],
                    "bypass": "AzureServices",
                    "virtualNetworkRules": [
                        // {
                        //     "condition": "[equals(parameters('DeployNetworkResources'),'true')]",
                        //     "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworks_name'))]",
                        //     "action": "Allow",
                        //     "state": "Succeeded"
                        // }
                    ],
                    // "copy": [
                    //     {
                    //         "name": "virtualNetworkRules",
                    //         "count": "[if(equals(parameters('DeployNetworkResources'),'false'), 0, 1)]",
                    //         "input": {
                    //             "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworks_name'))]", //"[concat(parameters('virtualNetwork_externalid'), '/subnets/snet-sdsd-it-ccw-dev-fl-001')]",
                    //             "action": "Allow",
                    //             "state": "Succeeded"
                    //         }
                    //     }
                    // ],
                    "ipRules": [],
                    "defaultAction": "Allow"
                },
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                    "requireInfrastructureEncryption": false,
                    "services": {
                        "file": {
                            "keyType": "Account",
                            "enabled": true
                        },
                        "blob": {
                            "keyType": "Account",
                            "enabled": true
                        }
                    },
                    "keySource": "Microsoft.Storage"
                },
                "accessTier": "Hot",
                "resources": [
                    {
                        "type": "blobServices",
                        "apiVersion": "2022-05-01",
                        "name": "/default",
                        "location": "[parameters('region')]",
                        "dependsOn": [
                            "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
                        ],
                        "sku": {
                            "name": "Standard_LRS",
                            "tier": "Standard"
                        },
                        "properties": {
                                "changeFeed": {
                                    "enabled": "[parameters('storageAccount').blobServices.changeFeed]"
                                },
                                "restorePolicy": {
                                    "enabled": "[parameters('storageAccount').blobServices.restorePolicy]"
                                },
                                "containerDeleteRetentionPolicy": {
                                    "enabled": "[parameters('storageAccount').blobServices.container.deleteRetentionPolicy]",
                                    "days": "[parameters('storageAccount').blobServices.container.retentionDays]"
                                },
                                "cors": {
                                    "corsRules": []
                                },
                                "deleteRetentionPolicy": {
                                    "allowPermanentDelete": false,
                                    "enabled": "[parameters('storageAccount').blobServices.deleteRetentionPolicy]",
                                    "days": "[parameters('storageAccount').blobServices.retentionDays]"
                                },
                                "isVersioningEnabled": "[parameters('storageAccount').blobServices.isVersioningEnabled]"
                            }
                    }//,
                //     {
                //         //"condition": "[parameters('deploy_rg')]",
                //         "type": "fileServices",
                //         "apiVersion": "2022-05-01",
                //         "name": "/default",
                //         "location": "[parameters('region')]",
                //         "dependsOn": [
                //             "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
                //         ],
                //         "sku": {
                //             "name": "Standard_LRS",
                //             "tier": "Standard"
                //         },
                //         "properties": {
                //             // "protocolSettings": {
                //             //     "smb": {}
                //             // },
                //             // "cors": {
                //             //     "corsRules": []
                //             // },
                //             "shareDeleteRetentionPolicy": {
                //                 "enabled": "[parameters('storageAccount').fileServices.retention]",
                //                 "days": "[parameters('storageAccount').fileServices.retentionDays]"
                //             }
                //         }
                //     },
                //     {
                //         "type": "queueServices",
                //         "apiVersion": "2022-05-01",
                //         "name": "/default",
                //         "dependsOn": [
                //             "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
                //         ],
                //         "properties": {
                //             "cors": {
                //                 "corsRules": []
                //             }
                //         }
                //     },
                //     {
                //         "type": "tableServices",
                //         "apiVersion": "2022-05-01",
                //         "name": "/default",
                //         "dependsOn": [
                //             "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
                //         ],
                //         "properties": {
                //             "cors": {
                //                 "corsRules": []
                //             }
                //         }
                //     }
                ]
            }
        },
        {
            // "condition": "[and(parameters('deploy_rg'), equals(empty(parameters('logAnalytics').name), 'false'))]",
            "condition": "[parameters('logAnalytics').deploy]",
            "type": "Microsoft.Operationalinsights/workspaces",
            "apiVersion": "2021-12-01-preview",
            "name": "[variables('logAnalytics_name')]",
            "location": "[parameters('region')]",
            "properties": {
                "sku": {
                    "name": "pergb2018"
                },
                "retentionInDays": 30,
                "features": {
                    "enableLogAccessUsingOnlyResourcePermissions": true
                },
                "workspaceCapping": {
                    "dailyQuotaGb": -1
                },
                "publicNetworkAccessForIngestion": "Disabled",
                "publicNetworkAccessForQuery": "Disabled"
            }
        },
        {
            "condition": "[parameters('keyVault').deploy]",
            "type": "Microsoft.KeyVault/vaults",
            "apiVersion": "2022-07-01",
            "name": "[variables('keyVault_name')]",
            "location": "[parameters('region')]",
            "tags": {
                "agency_name": "sdsd",
                "agency_ori": "ca0370000",
                "application_name": "ccw",
                "business_unit": "it",
                "criticality": "low",
                "data_classification": "general",
                "environment": "dev",
                "owner_name": "jkellash@californiasheriffs.onmicrosoft.com",
                "start_date": "09/29/2022"
            },
            "properties": {
                "sku": {
                    "family": "A",
                    "name": "Standard"
                },
                "tenantId": "[parameters('keyVault').id]",
                "accessPolicies": [],
                "enabledForDeployment": false,
                "enabledForDiskEncryption": false,
                "enabledForTemplateDeployment": false,
                "enableSoftDelete": true,
                "softDeleteRetentionInDays": 7,
                "enableRbacAuthorization": true,
                "vaultUri": "[concat('https://', variables('keyVault_name'), '.vault.usgovcloudapi.net/')]",
                "provisioningState": "Succeeded",
                "publicNetworkAccess": "Enabled"
            }
        },
        {
            "condition": "[parameters('keyVault').deploy]",
            "type": "Microsoft.KeyVault/vaults/secrets",
            "apiVersion": "2022-07-01",
            "name": "[if(empty(parameters('keyVault').secrets), concat(variables('keyVault_name'), '/empty'), variables('keyVault_secrets_name')[copyIndex('secrets')].name)]",
            "location": "[parameters('region')]",
            "dependsOn": [
                "[resourceId('Microsoft.KeyVault/vaults', variables('keyVault_name'))]"
            ],
            "properties": {
                "attributes": {
                    "enabled": true
                }
            },
            "copy": {
                "name": "secrets",
                "count": "[if(empty(parameters('keyVault').secrets), 0, length(variables('keyVault_secrets_name')))]"
            }
        },
        {
            "condition": "[parameters('cosmosDB').deploy]",
            "type": "Microsoft.DocumentDB/databaseAccounts",
            "apiVersion": "2022-08-15",
            "name": "[variables('cosmosDB_name')]",
            "location": "[parameters('region')]",
            "tags": {
                "defaultExperience": "Core (SQL)",
                "hidden-cosmos-mmspecial": "",
                "agency_name": "sdsd",
                "agency_ori": "ca0370000",
                "application_name": "ccw",
                "business_unit": "it",
                "criticality": "low",
                "data_classification": "general",
                "environment": "dev",
                "owner_name": "jkellash@californiasheriffs.onmicrosoft.com",
                "start_date": "09/29/2022"
            },
            "kind": "GlobalDocumentDB",
            "identity": {
                "type": "None"
            },
            "properties": {
                "publicNetworkAccess": "Enabled",
                "enableAutomaticFailover": false,
                "enableMultipleWriteLocations": false,
                "isVirtualNetworkFilterEnabled": false,
                "virtualNetworkRules": [],
                "disableKeyBasedMetadataWriteAccess": false,
                "enableFreeTier": false,
                "enableAnalyticalStorage": false,
                "analyticalStorageConfiguration": {
                    "schemaType": "WellDefined"
                },
                "databaseAccountOfferType": "Standard",
                "defaultIdentity": "FirstPartyIdentity",
                "networkAclBypass": "None",
                "disableLocalAuth": false,
                "enablePartitionMerge": false,
                "consistencyPolicy": {
                    "defaultConsistencyLevel": "Session",
                    "maxIntervalInSeconds": 5,
                    "maxStalenessPrefix": 100
                },
                "locations": [
                    {
                        "locationName": "[parameters('region')]",
                        "provisioningState": "Succeeded",
                        "failoverPriority": 0,
                        "isZoneRedundant": false
                    }
                ],
                "cors": [],
                "capabilities": [
                    {
                        "name": "EnableServerless"
                    }
                ],
                "ipRules": [],
                "backupPolicy": {
                    "type": "Periodic",
                    "periodicModeProperties": {
                        "backupIntervalInMinutes": 240,
                        "backupRetentionIntervalInHours": 8,
                        "backupStorageRedundancy": "Geo"
                    }
                },
                "networkAclBypassResourceIds": [],
                "keysMetadata": {}
            }
        },
        {
            "condition": "[parameters('cosmosDB').deploy]",
            "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
            "apiVersion": "2022-08-15",
            "name": "[concat(variables('cosmosDB_name'), '/', parameters('cosmosDB').sqlDatabases.id)]", //'appointment-db')]",
            "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosDB_name'))]"
            ],
            "properties": {
                "resource": {
                    "id": "[parameters('cosmosDB').sqlDatabases.id]"
                }
            },
            "copy": {
                "name": "sqlDatabases",
                "count": "[if(empty(parameters('cosmosDB').sqlDatabases.id), 0, 1)]"
            }
        },
        {
            "condition": "[parameters('cosmosDB').deploy]",
            "type": "Microsoft.DocumentDB/databaseAccounts/sqlRoleDefinitions",
            "apiVersion": "2022-08-15",
            "name": "[concat(variables('cosmosDB_name'), '/00000000-0000-0000-0000-00000000000', copyIndex('roleDefinitions'))]",
            "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosDB_name'))]"
            ],
            "properties": {
                "roleName": "[parameters('cosmosDB').roleDefinitions[copyIndex('roleDefinitions')].name]",
                "type": "BuiltInRole",
                "assignableScopes": [
                    "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosDB_name'))]"
                ],
                "permissions": [
                    {
                        "dataActions": [
                            "[parameters('cosmosDB').roleDefinitions[copyIndex('roleDefinitions')].permissions]"
                        ],
                        "notDataActions": []
                    }
                ]
            },
            "copy": {
                "name": "roleDefinitions",
                "count": "[if(empty(parameters('cosmosDB').roleDefinitions), 0, length(parameters('cosmosDB').roleDefinitions))]" //check .name
            }
        },
        {
            "condition": "[parameters('cosmosDB').deploy]",
            "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
            "apiVersion": "2022-08-15",
            "name": "[concat(variables('cosmosDB_name'), '/', parameters('cosmosDB').sqlDatabases.id, '/', parameters('cosmosDB').sqlDatabases.containers[copyIndex('sqlDatabases_containers')])]",
            "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', variables('cosmosDB_name'), parameters('cosmosDB').sqlDatabases.id)]",
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosDB_name'))]"
            ],
            "properties": {
                "resource": {
                    "id": "[parameters('cosmosDB').sqlDatabases.containers[copyIndex('sqlDatabases_containers')]]",
                    "indexingPolicy": {
                        "indexingMode": "consistent",
                        "automatic": true,
                        "includedPaths": [
                            {
                                "path": "/*"
                            }
                        ],
                        "excludedPaths": [
                            {
                                "path": "/\"_etag\"/?"
                            }
                        ]
                    },
                    "partitionKey": {
                        "paths": [
                            "/id"
                        ],
                        "kind": "Hash"
                    },
                    "uniqueKeyPolicy": {
                        "uniqueKeys": []
                    },
                    "conflictResolutionPolicy": {
                        "mode": "LastWriterWins",
                        "conflictResolutionPath": "/_ts"
                    }
                }
            },
            "copy": {
                "name": "sqlDatabases_containers",
                "count": "[if(empty(parameters('cosmosDB').sqlDatabases.containers), 0, length(parameters('cosmosDB').sqlDatabases.containers))]"
            }
        }
    ],
    "outputs": {
        "resourcegroup_name": {
            "condition": "[parameters('deploy_rg')]",
            "type": "string",
            "value": "[parameters('rg_name')]"
        },
        "key_vault_name": {
        "condition": "[parameters('keyVault').deploy]",
        "type": "string",
        "value": "[variables('keyVault_name')]"
        },
        "subscription": {
        "type": "object",
        "value": "[subscription()]"
        }//,
        // "apim_name": {
        // "condition": "[parameters('deploy_rg')]",
        // "type": "string",
        // "value": "[variables('service_ripa_apim_wus2_name')]"
        // },
        // "cosmosdb_name": {
        // "condition": "[parameters('deploy_rg')]",
        // "type": "string",
        // "value": "[variables('databaseAccounts_ripa_cdb_name')]"
        // },
        // "functionapp_name": {
        // "condition": "[parameters('deploy_rg')]",
        // "type": "string",
        // "value": "[variables('sites_ripa_user_fa_name')]"
        // }
    }
}