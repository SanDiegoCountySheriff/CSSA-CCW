            ],
            "tags": {
                "agency_name": "[parameters('agency')]",
                "agency_ori": "ca0370000",
                "application_name": "[parameters('application')]",
                "business_unit": "[parameters('dept')]",
                "criticality": "low",
                "data_classification": "general",
                "environment": "[parameters('environment')]",
                "owner_name": "[concat(parameters('owner_name'), '@californiasheriffs.onmicrosoft.com')]",
                "start_date": "09/29/2022"
            },
            "kind": "app,linux",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "enabled": true,
                "hostNameSslStates": [
                    {
                        "name": "[concat(variables('webSites_name')[copyIndex('sites')].name, '.azurewebsites.us')]",
                        "sslState": "Disabled",
                        "hostType": "Standard"
                    },
                    {
                        "name": "[concat(variables('webSites_name')[copyIndex('sites')].name, '.scm.azurewebsites.us')]",
                        "sslState": "Disabled",
                        "hostType": "Repository"
                    }
                ],
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('serverFarms_name'))]",
                "reserved": true,
                "isXenon": false,
                "hyperV": false,
                "vnetRouteAllEnabled": false,
                "vnetImagePullEnabled": false,
                "vnetContentShareEnabled": false,
                "siteConfig": {
                    "numberOfWorkers": 1,
                    "linuxFxVersion": "DOTNETCORE|6.0",
                    "acrUseManagedIdentityCreds": false,
                    "alwaysOn": true,
                    "http20Enabled": false,
                    "functionAppScaleLimit": 0,
                    "minimumElasticInstanceCount": 0
                },
                "scmSiteAlsoStopped": false,
                "clientAffinityEnabled": false,
                "clientCertEnabled": false,
                "clientCertMode": "Required",
                "hostNamesDisabled": false,
                "customDomainVerificationId": "9FE01B0A8428EC8A4CD7CDDBE9F3E3D2A089A715319DF71C18A08E8B1F0FE4EE",
                "containerSize": 0,
                "dailyMemoryTimeQuota": 0,
                "httpsOnly": true,
                "redundancyMode": "None",
                "storageAccountRequired": false,
                "keyVaultReferenceIdentity": "SystemAssigned"
            },
            "resources": [
                {
                    "type": "Microsoft.Web/sites/hostNameBindings",
                    "apiVersion": "2022-03-01",
                    // "name": "[if(empty(parameters('webSites').sites[0].name), concat(variables('sites_name'), '/', variables('sites_name'), '.azurewebsites.us'), concat(variables('webSites_name')[copyIndex('sites')].name, '/', variables('webSites_name')[copyIndex('sites')].name, '.azurewebsites.us'))]",
                    "name": "[concat(variables('webSites_name')[copyIndex('sites')].name, '/', variables('webSites_name')[copyIndex('sites')].name, '.azurewebsites.us')]",
                    "location": "[parameters('region')]",
                    "dependsOn": [
                        "[resourceId('Microsoft.Web/sites', variables('webSites_name')[copyIndex('sites')].name)]"
                    ],
                    "properties": {
                        "siteName": "[variables('webSites_name')[copyIndex('sites')].name]",
                        "hostNameType": "Verified"
                    }
                }
            ],
            "copy": {
                "name": "sites",
                "count": "[length(variables('webSites_name'))]"
            }
        },
