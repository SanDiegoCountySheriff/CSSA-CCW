{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "agency": {
            "type": "string",
            "defaultValue": "sdsd",
            "metadata": {
                "description": "Agency identifier varies based on agency."
            }
        },
        "application": {
            "type": "string",
            "defaultValue": "ccw"
        },
        "cosmosDB": {
            "type": "object"
        },
        "deploy_rg": {
            "type": "bool"
        },
        "dept": {
            "type": "string",
            "defaultValue": "it"
        },
        // "DeployNetworkResources": {
        //     "type": "Bool"
        // },
        "environment": {
            "type": "string",
            "defaultValue": "dev",
            "allowedValues": [ "dev" ]
        },
        "keyVault": {
            "type": "object"
        },
        "keyVault_tenantId": {
            "type": "string",
            "defaultValue": "[subscription().tenantId]",
            "metadata": {
                "description": "Specifies the Azure Active Directory tenant ID that should be used for authenticating requests to the key vault. Get it by using Get-AzSubscription cmdlet."
            }
        },
        // "keyVault_secretsPermissions": {
        //     "type": "array",
        //     "defaultValue": [ "Get", "List" ],
        //     "metadata": {
        //         "description": "Specifies the permissions to secrets in the vault. Valid values are: all, get, list, set, delete, backup, restore, recover, and purge."
        //     }
        // },
        // "keyVault_keysPermissions": {
        //     "type": "array",
        //     "defaultValue": [ "Get", "List" ],
        //     "metadata": {
        //         "description": "Specifies the permissions to keys in the vault. Valid values are: all, get, list, set, delete, backup, restore, recover, and purge."
        //     }
        // },
        // "keyVault_certPermissions": {
        //     "type": "array",
        //     "defaultValue": [ "Get", "List" ],
        //     "metadata": {
        //         "description": "Specifies the permissions to keys in the vault. Valid values are: all, get, list, set, delete, backup, restore, recover, and purge."
        //     }
        // },
        "logAnalytics": {
            "type": "object"
        },
        "owner_name": {
            "type": "string",
            "defaultValue": "jkellash"
        },
        "region": {
            "type": "string",
            "defaultValue": "[resourceGroup().location]"
        },
        "resource_cosmosDB": {
            "type": "string",
            "defaultValue": "cdb"
        },
        "resource_keyVault": {
            "type": "string",
            "defaultValue": "kv"
        },
        "resource_logAnalytics": {
            "type": "string",
            "defaultValue": "law"
        },
        "resource_serverFarms": {
            "type": "string",
            "defaultValue": "asp"
        }, 
        "resource_storageAccount": {
            "type": "string",
            "defaultValue": "sa"
        },
        "resource_webSites": {
            "type": "string",
            "defaultValue": "wa"
        }, 
        "rg_name": {
            "type": "string",
            "defaultValue": "[resourceGroup().name]"
        },
        "serverFarms": {
            "type": "object"
        },
        "storageAccount": {
            "type": "object"
        },
        "webSites": {
            "type": "object"
        }
        // "virtualNetwork_externalid": {
        //     "defaultValue": "/subscriptions/c74e04b6-0cd7-4778-863e-34654eb49270/resourceGroups/rg-sdsd-it-ccw-dev-001/providers/Microsoft.Network/virtualNetworks/vnet-sdsd-it-ccw-dev-001",
        //     "type": "string"
        // }
        // "virtualNetworks_vnet": {
        //     "defaultValue": "test",
        //     "type": "string"
        // }
    },
    "variables": {
        "copy": [
            {
                "name": "keyVault_secrets_name",
                "count": "[if(empty(parameters('keyVault').secrets[0].name), 0, length(parameters('keyVault').secrets))]",
                "input": {
                    "name": "[concat(variables('keyVault_name'), '/', parameters('keyVault').secrets[copyIndex('keyVault_secrets_name')].name)]"
                }
            },
            {
                "name": "storageAccount_container_name",
                "count": "[length(parameters('storageAccount').containers)]",
                "input": {
                    "name": "[concat(variables('storageAccount_name'), '/default/', parameters('storageAccount').containers[copyIndex('storageAccount_container_name')])]"
                }
            },
            {
                "name": "webSites_name",
                "count": "[if(empty(parameters('webSites').sites[0].name), 0, length(parameters('webSites').sites))]",
                "input": {
                    "name": "[concat(variables('sites_name'), '-', parameters('webSites').sites[copyIndex('webSites_name')].name, '-', parameters('webSites').sites[copyIndex('webSites_name')].number)]"
                }
            }
        ],
        "storageAccount_name": "[concat(parameters('resource_storageAccount'), parameters('agency'), parameters('dept'), parameters('application'), parameters('environment'), if(empty(parameters('storageAccount').name), 'empty', parameters('storageAccount').name), parameters('storageAccount').number)]",
        "logAnalytics_name": "[concat(parameters('resource_logAnalytics'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'), '-', if(empty(parameters('logAnalytics').name), 'empty', parameters('logAnalytics').name), '-', parameters('logAnalytics').number)]",
        "keyVault_name": "[concat(parameters('resource_keyVault'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'), '-', parameters('keyVault').number)]",
        "cosmosDB_name": "[concat(parameters('resource_cosmosDB'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'), '-', parameters('cosmosDB').number)]",
        "serverFarms_name": "[concat(parameters('resource_serverFarms'), '-', parameters('resource_webSites'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'), '-', parameters('serverFarms').number)]",
        "sites_name": "[concat(parameters('resource_webSites'), '-', parameters('agency'), '-', parameters('dept'), '-', parameters('application'), '-', parameters('environment'))]"
        //"virtualNetworks_name": "[concat(parameters('agency'),'-', parameters('application'), '-',parameters('environment'),'-', parameters('virtualNetworks_vnet'), '-vnet')]"
    },
    "resources": [
