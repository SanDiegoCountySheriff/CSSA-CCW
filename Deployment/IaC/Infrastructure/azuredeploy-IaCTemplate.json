{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "rg_name": {
            "defaultValue": "[resourceGroup().name]",
            "type": "string"
        },
        "deploy_rg": {
            //"defaultValue": true,
            "type": "bool"
        },
        "agency": {
            "defaultValue": "sdsd",
            "type": "string",
            "metadata": {
                "description": "Agency identifier varies based on agency."
            }
        },
        "environment": {
            "defaultValue": "dev",
            "type": "string",
            "allowedValues": [ "dev" ]
        },
        "application": {
            "defaultValue": "ccw",
            "type": "string"
        },
        "region": {
            "defaultValue": "[resourceGroup().location]",
            "type": "string"
        },
        "storageAccount": {
            //"defaultValue": "test",
            "type": "String"
        },
        "blobServices_changeFeed": {
            //"defaultValue": "true",
            "type": "String",
            "allowedValues": ["off", "true", "false"],
            "metadata": {
                "description": "off will remove property from resource"
            }
        },
        "blobServices_restorepolicy": {
            //"defaultValue": "true",
            "type": "String",
            "allowedValues": [ "off", "true", "false" ],
            "metadata": {
                "description": "off will remove property from resource"
            }
        },
        "blobServices_containerDeleteRetentionPolicy": {
            //"defaultValue": "true",
            "type": "String",
            "allowedValues": [ "off", "true", "false" ],
            "metadata": {
                "description": "off will remove property from resource"
            }
        },
        "blobServices_containerRetention_days": {
            //"defaultValue": 1,
            "type": "int"
        },
        "blobServices_deleteRetentionPolicy": {
            //"defaultValue": true,
            "type": "bool"
        },
        "blobServices_retention_days": {
            //"defaultValue": 1,
            "type": "int"
        },
        "blobServices_isVersioningEnabled": {
            //"defaultValue": "true",
            "type": "String",
            "allowedValues": [ "off", "true", "false" ],
            "metadata": {
                "description": "off will remove property from resource"
            }
        },
        "blobServices_container": {
            //"defaultValue": "$web",
            "type": "String"
        },
        "fileServices_retention": {
            //"defaultValue": true,
            "type": "bool"
        },
        "fileServices_retentionDays": {
            //"defaultValue": 1,
            "type": "int"
        },
        "DeployNetworkResources": {
            //"defaultValue": false,
            "type": "Bool"
        },
        "privateEndpoint_id": {
            "type": "String"
        },
        // "virtualNetwork_externalid": {
        //     "defaultValue": "/subscriptions/c74e04b6-0cd7-4778-863e-34654eb49270/resourceGroups/rg-sdsd-it-ccw-dev-001/providers/Microsoft.Network/virtualNetworks/vnet-sdsd-it-ccw-dev-001",
        //     "type": "string"
        // }
        "virtualNetworks_vnet": {
            "defaultValue": "test",
            "type": "String"
        }
    },
    "variables": {
        "storageAccount_name": "[concat(parameters('agency'),'-', parameters('application'), '-',parameters('environment'),'-', if(equals(parameters('storageAccount'), 'test'), 'test', parameters('storageAccount')), '-sa')]",
        "storageAccount_default_name": "[concat(variables('storageAccount_name'), '/default')]",
        "storageAccount_container_name": "[concat(variables('storageAccount_name'), '/default/', parameters('blobServices_container'))]",
        "virtualNetworks_name": "[concat(parameters('agency'),'-', parameters('application'), '-',parameters('environment'),'-', parameters('virtualNetworks_vnet'), '-vnet')]"
    },
    "resources": [
        {
            "condition": "[parameters('deploy_rg')]",
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2022-05-01",
            "name": "[variables('storageAccount_name')]",
            "location": "[parameters('region')]",
            "tags": {
                "agency_name": "[parameters('agency')]",
                "agency_ori": "ca0370000",
                "application_name": "[parameters('application')]",
                "business_unit": "it",
                "criticality": "low",
                "data_classification": "general",
                "environment": "[parameters('environment')]",
                "owner_name": "jkellash@californiasheriffs.onmicrosoft.com",
                "start_date": "09/29/2022"
            },
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "kind": "StorageV2",
            "properties": {
                "publicNetworkAccess": "Enabled",
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": true,
                "allowSharedKeyAccess": true,
                "networkAcls": {
                    "resourceAccessRules": [],
                    "bypass": "AzureServices",
                    "copy": [
                        {
                            "name": "virtualNetworkRules",
                            "count": "[if(equals(parameters('DeployNetworkResources'),'false'), 0, 1)]",
                            "input": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworks_name'))]", //"[concat(parameters('virtualNetwork_externalid'), '/subnets/snet-sdsd-it-ccw-dev-fl-001')]",
                                "action": "Allow",
                                "state": "Succeeded"
                            }
                        }
                    ],
                    "ipRules": [],
                    "defaultAction": "Deny"
                },
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                    "requireInfrastructureEncryption": false,
                    "services": {
                        "file": {
                            "keyType": "Account",
                            "enabled": true
                        },
                        "blob": {
                            "keyType": "Account",
                            "enabled": true
                        }
                    },
                    "keySource": "Microsoft.Storage"
                },
                "accessTier": "Hot"
            }
        },
        {
            "condition": "[parameters('deploy_rg')]",
            "type": "Microsoft.Storage/storageAccounts/blobServices",
            "apiVersion": "2022-05-01",
            "name": "[variables('storageAccount_default_name')]",
            "location": "[parameters('region')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "properties": {
                "copy": [
                    {
                        "name": "changeFeed",
                        "count": "[if(equals(parameters('blobServices_changeFeed'),'off'), 0, 1)]",
                        "input": {
                            "enabled": "[if(equals(parameters('blobServices_changeFeed'),'true'), 'true', 'false')]"
                        }
                    },
                    {
                        "name": "restorePolicy",
                        "count": "[if(equals(parameters('blobServices_restorepolicy'),'off'), 0, 1)]",
                        "input": {
                            "enabled": "[if(equals(parameters('blobServices_restorePolicy'),'true'), 'true', 'false')]"
                        }
                    },
                    {
                        "name": "containerDeleteRetentionPolicy",
                        "count": "[if(equals(parameters('blobServices_containerDeleteRetentionPolicy'),'off'), 0, 1)]",
                        "input": {
                            "enabled": "[if(equals(parameters('blobServices_containerDeleteRetentionPolicy'),'true'), 'true', 'false')]",
                            "days": "[parameters('blobServices_containerRetention_days')]"
                        }
                    },
                    {
                        "name": "isVersioningEnabled",
                        "count": "[if(equals(parameters('blobServices_isVersioningEnabled'),'off'), 0, 1)]",
                        "input": {
                            "enabled": "[if(equals(parameters('blobServices_isVersioningEnabled'),'true'), 'true', 'false')]"
                        }
                    }
                ],
                "cors": {
                    "corsRules": []
                },
                "deleteRetentionPolicy": {
                    "allowPermanentDelete": false,
                    "enabled": "[if(equals(parameters('blobServices_deleteRetentionPolicy'), 'true'), 'true', 'false')]",
                    "days": "[parameters('blobServices_retention_days')]"
                }
            }
        },
        {
            "condition": "[parameters('deploy_rg')]",
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2022-05-01",
            "name": "[variables('storageAccount_container_name')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccount_name'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "properties": {
                "immutableStorageWithVersioning": {
                    "enabled": false
                },
                "defaultEncryptionScope": "$account-encryption-key",
                "denyEncryptionScopeOverride": false,
                "publicAccess": "None"
            }
        },
        {
            "condition": "[parameters('deploy_rg')]",
            "type": "Microsoft.Storage/storageAccounts/fileServices",
            "apiVersion": "2022-05-01",
            "name": "[variables('storageAccount_default_name')]",
            "location": "[parameters('region')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "properties": {
                "protocolSettings": {
                    "smb": {}
                },
                "cors": {
                    "corsRules": []
                },
                "shareDeleteRetentionPolicy": {
                    "enabled": "[if(equals(parameters('fileServices_retention'),'true'), 'true', 'false')]",
                    "days": "[parameters('fileServices_retentionDays')]" //changed from 0
                }
            }
        },
        {
            "condition": "[parameters('deploy_rg')]",
            "type": "Microsoft.Storage/storageAccounts/privateEndpointConnections",
            "apiVersion": "2022-05-01",
            "name": "[concat(variables('storageAccount_name'), '/', variables('storageAccount_name'), parameters('privateEndpoint_id'))]", //'.1134b2af-aec1-466c-aa59-984031c7df0d', '.1ae55f77-698f-4808-bee3-36f4eaa81e62'
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "properties": {
                "provisioningState": "Succeeded",
                "privateEndpoint": {},
                "privateLinkServiceConnectionState": {
                    "status": "Approved",
                    "description": "Auto-Approved",
                    "actionRequired": "None"
                }
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/queueServices",
            "apiVersion": "2022-05-01",
            "name": "[concat(variables('storageAccount_name'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "properties": {
                "cors": {
                    "corsRules": []
                }
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/tableServices",
            "apiVersion": "2022-05-01",
            "name": "[concat(variables('storageAccount_name'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccount_name'))]"
            ],
            "properties": {
                "cors": {
                    "corsRules": []
                }
            }
        }
    ],
    "outputs": {
        "resourcegroup_name": {
            "condition": "[parameters('deploy_rg')]",
            "type": "string",
            "value": "[parameters('rg_name')]"
        }
    }
}